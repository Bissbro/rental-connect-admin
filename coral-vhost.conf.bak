<VirtualHost *:80>
    ServerName coral.api.htmrentals.com
    
    # Serve tenant.js from tenant-specific folder
    Alias /tenant.js /home/bitnami/rental-connect-guest/coral/tenant.js
    
    # Serve all other guest files from shared folder
    DocumentRoot /home/bitnami/rental-connect-guest
    
    <Directory /home/bitnami/rental-connect-guest>
        Options -Indexes
        AllowOverride None
        Require all granted
    </Directory>
    
    # Proxy API calls to Express
    ProxyPass /api http://localhost:3000/api
    ProxyPassReverse /api http://localhost:3000/api
    ProxyPass /uploads http://localhost:3000/uploads
    ProxyPassReverse /uploads http://localhost:3000/uploads
</VirtualHost>

<VirtualHost *:443>
    ServerName coral.api.htmrentals.com
    SSLEngine on
    SSLCertificateFile "/etc/letsencrypt/live/coral.api.htmrentals.com/fullchain.pem"
    SSLCertificateKeyFile "/etc/letsencrypt/live/coral.api.htmrentals.com/privkey.pem"

    # Serve tenant.js from tenant-specific folder
    Alias /tenant.js /home/bitnami/rental-connect-guest/coral/tenant.js

    # Serve all other guest files from shared folder
    DocumentRoot /home/bitnami/rental-connect-guest

    <Directory /home/bitnami/rental-connect-guest>
        Options -Indexes
        AllowOverride None
        Require all granted
    </Directory>

    # Proxy API calls to Express
    ProxyPass /api http://localhost:3000/api
    ProxyPassReverse /api http://localhost:3000/api
    ProxyPass /uploads http://localhost:3000/uploads
    ProxyPassReverse /uploads http://localhost:3000/uploads
</VirtualHost>
